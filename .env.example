# ═══════════════════════════════════════════════════════════════════════
# Signal AI Agent — Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# MODE: uncomment ONE URL pair below (Docker OR Host).
# The scripts/run-host.sh and scripts/run-docker.sh handle this
# automatically, but you can also toggle manually.
# ═══════════════════════════════════════════════════════════════════════

# ── Docker mode (bot runs in container) ──────────────────────────────
# Use these when running via: ./scripts/up.sh
#LLM_BASE_URL=http://host.docker.internal:1234/v1
#SIGNAL_API_URL=http://signal-api:8080

# ── Host mode (bot runs directly on macOS/Linux) ─────────────────────
# Use these when running via: ./scripts/run-host.sh
LLM_BASE_URL=http://localhost:1234/v1
SIGNAL_API_URL=http://localhost:9922

# ── LLM settings ─────────────────────────────────────────────────────
LLM_API_KEY=lm-studio
LLM_MODEL=qwen2.5-14b-instruct
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ── Signal ────────────────────────────────────────────────────────────
# Your bot's Signal phone number in international format
SIGNAL_NUMBER=+1234567890

# Optional: restrict who can message the bot (comma-separated)
# ALLOWED_NUMBERS=+14155551234,+14155559999

# ── Whisper (voice transcription) ─────────────────────────────────────
# Model sizes: tiny, base, small, medium, large-v3
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
